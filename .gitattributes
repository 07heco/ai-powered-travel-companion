# 文本文件 - 自动转换换行符
* text=auto

# Java源文件
*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf

# 前端文件
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf

# Windows批处理文件
*.bat text eol=crlf
*.cmd text eol=crlf

# Maven Wrapper脚本
mvnw text eol=lf
mvnw.cmd text eol=crlf

# 二进制文件 - 不转换
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.pdf binary
*.zip binary
*.jar binary
*.class binary
*.dll binary
*.exe binary

