# =====================================================
# AI-Powered Travel Companion 环境变量配置示例
# =====================================================
# 复制此文件为 .env 并根据实际情况修改配置
# =====================================================

# =====================================================
# 数据库配置
# =====================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=travel_companion
DB_USERNAME=root
DB_PASSWORD=your_password

# =====================================================
# Redis配置
# =====================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# =====================================================
# Nacos配置
# =====================================================
NACOS_SERVER_ADDR=localhost:8848
NACOS_NAMESPACE=
NACOS_GROUP=DEFAULT_GROUP

# =====================================================
# JWT配置
# =====================================================
JWT_SECRET=your_super_secret_key_at_least_256_bits_long
JWT_EXPIRATION=86400000

# =====================================================
# 第三方服务配置
# =====================================================
# OpenAI API配置
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com

# 短信服务配置
SMS_ACCESS_KEY_ID=your_access_key_id
SMS_ACCESS_KEY_SECRET=your_access_key_secret
SMS_SIGN_NAME=AI旅游助手
SMS_TEMPLATE_CODE=your_template_code

# 支付配置
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_private_key
ALIPAY_PUBLIC_KEY=alipay_public_key

WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# =====================================================
# 文件存储配置
# =====================================================
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET_NAME=travel-companion

# =====================================================
# 服务端口配置
# =====================================================
GATEWAY_PORT=8080
USER_SERVICE_PORT=8081
DESTINATION_SERVICE_PORT=8082
TRIP_SERVICE_PORT=8083
BOOKING_SERVICE_PORT=8084
PAYMENT_SERVICE_PORT=8085
AI_SERVICE_PORT=8086
MESSAGE_SERVICE_PORT=8087
WALLET_SERVICE_PORT=8088
DEALS_SERVICE_PORT=8089

# =====================================================
# 日志配置
# =====================================================
LOG_LEVEL=INFO
LOG_PATH=./logs

# =====================================================
# 其他配置
# =====================================================
# 开发环境设置
SPRING_PROFILES_ACTIVE=dev

# 允许的跨域源
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000